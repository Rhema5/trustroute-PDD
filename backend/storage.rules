rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /proofs/{fileName} {
      // Helper function to extract the delivery ID from the proof filename
      // e.g. fileName is "{deliveryId}_{timestamp}.jpg"
      function getDeliveryId() {
        return fileName.split('_')[0];
      }

      function getDeliveryData() {
        return firestore.get(/databases/(default)/documents/deliveries/$(getDeliveryId())).data;
      }

      function isAssignedAgent() {
        return getDeliveryData().agentId == request.auth.uid;
      }

      function isEnterpriseOwner() {
        return getDeliveryData().enterpriseId == request.auth.uid;
      }

      // Restrict read/write to users assigned to or owning the delivery associated with this proof
      allow read: if request.auth != null && (isEnterpriseOwner() || isAssignedAgent());
      allow write: if request.auth != null && (isEnterpriseOwner() || isAssignedAgent());
    }
  }
}
