# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
.output
.vinxi
.tanstack/**
.nitro
*.local

# Wrangler / Cloudflare
.wrangler/
.dev.vars

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.vercel

# Local Netlify folder
.netlify

# Environment files
.env
.env.local
.env.*.local
*.env

# Automation — ignore runtime artifacts but keep reports
automation/logs/
automation/screenshots/
automation/__pycache__/
automation/**/__pycache__/
automation/**/*.pyc
automation/config/__pycache__/

# k6 local results (CI will generate and upload as artifacts)
testing/load-results.json

# Keep Test Results/ tracked in git
!Test Results/
!Test Results/**

# Mobile app — exclude large binary build artifacts
mobile-app/android/gradle/wrapper/gradle-wrapper.jar
mobile-app/android/.gradle/
mobile-app/android/build/
mobile-app/android/app/build/
mobile-app/node_modules/

# Exclude large splash/icon PNGs that bloat the push
mobile-app/android/app/src/main/res/drawable*/splash.png
mobile-app/android/app/src/main/res/mipmap-hdpi/
mobile-app/android/app/src/main/res/mipmap-mdpi/
mobile-app/android/app/src/main/res/mipmap-xhdpi/
mobile-app/android/app/src/main/res/mipmap-xxhdpi/
mobile-app/android/app/src/main/res/mipmap-xxxhdpi/

# Exclude large lock files from root
package-lock.json
bun.lock
